# --- Database ---
DATABASE_URL="postgresql://agenttrace:agenttrace@localhost:5432/agenttrace?schema=public"

# --- API ---
API_PORT=4000
API_HOST=0.0.0.0
# Comma-separated list of accepted API keys for write endpoints.
API_KEYS="dev_key_local"

# Ed25519 signing key for receipts (hex-encoded 32-byte seed / PKCS8).
# Generate with: pnpm keys:generate
RECEIPT_SIGNING_KEY=""
RECEIPT_PUBLIC_KEY=""

# --- Dashboard ---
# Base URL the dashboard uses to reach the API (server-side).
AGENTTRACE_API_URL="http://localhost:4000"
NEXT_PUBLIC_AGENTTRACE_API_URL="http://localhost:4000"
